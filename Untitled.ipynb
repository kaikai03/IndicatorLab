   "source": [
    "def make_half_life_ind(period):\n",
    "    return np.exp(np.log(0.5)/period)\n",
    "\n",
    "def weight_half_life(T,period):\n",
    "    '''T 当前轮数， period：半衰期长度'''\n",
    "    return round(np.power(make_half_life_ind(50), 50),8)"
   ]
